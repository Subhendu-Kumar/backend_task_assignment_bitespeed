# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/bitespeed

# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=Bitespeed Identity Service
APP_VERSION=1.0.0
DEBUG=false

# ── JWT ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=*
